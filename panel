// --- CÁLCULO DE RECURRENCIA E INDICADOR DE FIDELIDAD (ANALÍTICA DE VISITAS) ---
function formatVisitDate(isoDate) {
  const d = new Date(isoDate + "T00:00:00");
  return d.toLocaleDateString('es-PE', { day: '2-digit', month: 'short' });
}

function computeClientActivity(userId) {
  const card = DB.loyaltyCards.find(c => c.user_id === userId);
  if (!card) return null;

  const visits = DB.transactions
    .filter(t => t.card_id === card.id && t.type === 'stamp_add' && t.visit_date)
    .sort((a, b) => a.visit_date.localeCompare(b.visit_date));

  if (visits.length === 0) {
    return { totalVisits: 0, firstVisit: null, lastVisit: null, lastVisitTime: null, avgIntervalDays: null, fidelity: "🆕 Sin visitas", fidelityClass: "nuevo" };
  }

  const first = visits[0];
  const last = visits[visits.length - 1];
  const daysSpan = (new Date(last.visit_date) - new Date(first.visit_date)) / 86400000;
  const avgIntervalDays = visits.length > 1 ? Math.round((daysSpan / (visits.length - 1)) * 10) / 10 : null;

  let fidelity, fidelityClass;
  if (visits.length === 1) { fidelity = "🆕 Nuevo"; fidelityClass = "nuevo"; }
  else if (avgIntervalDays <= 7) { fidelity = "🔥 Alta"; fidelityClass = "alta"; }
  else if (avgIntervalDays <= 15) { fidelity = "🙂 Media"; fidelityClass = "media"; }
  else { fidelity = "💤 Baja"; fidelityClass = "baja"; }

  return {
    totalVisits: visits.length,
    firstVisit: first.visit_date,
    lastVisit: last.visit_date,
    lastVisitTime: last.created_at,
    avgIntervalDays,
    fidelity,
    fidelityClass
  };
}

function generateCouponCode() {
  const chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789"; // sin caracteres ambiguos
  let code = "";
  for (let i = 0; i < 6; i++) code += chars[Math.floor(Math.random() * chars.length)];
  // Aseguramos unicidad frente a cupones ya generados
  if (DB.giftedCoupons.some(c => c.coupon_code === code)) return generateCouponCode();
  return code;
}

// --- LOGICA DE CRECIMIENTO, RECOMPENSAS Y CAMBIO DE NIVEL ---
function executeAddStamp(cardId) {
  const card = DB.loyaltyCards.find(c => c.id === cardId);
  const biz = DB.businesses.find(b => b.id === card.business_id);

  if (card.reward_ready) {
    triggerToast("¡El cliente ya posee un premio pendiente de canje!");
    return;
  }

  const prevPlumas = card.total_historical_plumas;

  // Regla de Negocio: 1 Sello = 1 Pluma
  card.current_stamps += 1;
  card.total_historical_plumas += 1;

  // Sincroniza experience_points en la dimensión Users
  const user = DB.users.find(u => u.id === card.user_id);
  if (user) user.experience_points = card.total_historical_plumas;

  // Registro del evento transaccional puro
  const now = new Date();
  DB.transactions.push({
    id: "TX-" + Math.floor(Math.random() * 9000 + 1000),
    card_id: card.id,
    type: "stamp_add",
    amount_stamps: 1,
    amount_plumas: 1,
    created_at: now.toLocaleTimeString('es-PE', { hour: '2-digit', minute: '2-digit', second: '2-digit' }),
    visit_date: now.toISOString().slice(0, 10)
  });

  const crossedGold = prevPlumas < 30 && card.total_historical_plumas >= 30;
  const crossedSilver = !crossedGold && prevPlumas < 10 && card.total_historical_plumas >= 10;

  if (card.current_stamps >= biz.max_sellos_recompensa) {
    card.reward_ready = true;
    triggerToast(`🎁 ¡Ciclo completado! Premio habilitado para ${user.name}`);
  } else {
    triggerToast("+1 Pluma / Sello otorgado correctamente");
  }

  renderAll();

  if (crossedGold) showLevelUpModal("Oro", user);
  else if (crossedSilver) showLevelUpModal("Plata", user);
}

function executeRedeemReward(cardId) {
  const card = DB.loyaltyCards.find(c => c.id === cardId);
  if (!card.reward_ready) return;

  DB.transactions.push({
    id: "TX-" + Math.floor(Math.random() * 9000 + 1000),
    card_id: card.id,
    type: "reward_redeem",
    amount_stamps: -10,
    amount_plumas: 0,
    created_at: new Date().toLocaleTimeString('es-PE', { hour: '2-digit', minute: '2-digit', second: '2-digit' })
  });

  card.current_stamps = 0;
  card.reward_ready = false;

  triggerToast("Premio entregado. Tarjeta reiniciada para acumulación.");
  renderAll();
}

