// --- VALIDACIÓN DE CUPONES EN CAJA (COMERCIO) ---
function validateCouponCode() {
  const input = document.getElementById('coupon-validate-input');
  const feedback = document.getElementById('coupon-validate-feedback');
  const code = (input.value || "").trim().toUpperCase();

  feedback.className = "validate-feedback";
  if (!code) {
    feedback.classList.add('err');
    feedback.textContent = "Ingresa un código de 6 caracteres.";
    return;
  }

  const coupon = DB.giftedCoupons.find(c => c.coupon_code === code);
  if (!coupon) {
    feedback.classList.add('err');
    feedback.textContent = `Código "${code}" no encontrado en la base de datos.`;
    triggerToast("Cupón no encontrado");
    return;
  }
  if (coupon.status === "redeemed") {
    feedback.classList.add('err');
    feedback.textContent = `Este cupón ya fue canjeado previamente.`;
    triggerToast("Cupón ya canjeado");
    return;
  }

  coupon.status = "redeemed";
  feedback.classList.add('ok');
  feedback.textContent = `✅ Validado: ${coupon.experience_title} — ${coupon.merchant_name}`;
  triggerToast("🎁 Cupón de regalo canjeado correctamente");
  input.value = "";
  renderAll();
}

