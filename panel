<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gold Bird — Entorno de Simulación y Arquitectura de Datos</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,500&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0A0C10;
    --surface:#14171F;
    --surface-2:#1A1E28;
    --border:rgba(201,162,39,0.3);
    --border-soft:rgba(242,239,230,0.08);
    --gold:#C9A227;
    --gold-light:#E8C874;
    --text:#F2EFE6;
    --text-dim:#9C9A90;
    --text-faint:#6B6A63;
    --bronze:#B08D57;
    --silver:#C7CAD1;
    --oro:#E8C874;
    --danger:#D96C5F;
    --success:#77B255;
    --radius-lg:16px;
    --radius-md:10px;
    --feather-icon:url("data:image/webp;base64,");
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  body{background:var(--bg); color:var(--text); font-family:'Inter',sans-serif; padding:2rem 1rem; -webkit-font-smoothing:antialiased;}
  .container{max-width:1200px; margin:0 auto;}

  header{text-align:center; margin-bottom:2.5rem;}
  header h1{font-family:'Fraunces',serif; font-weight:500; color:var(--gold-light); font-size:32px;}
  header p{color:var(--text-dim); font-size:14px; margin-top:5px;}

  /* --- GRID PRINCIPAL DE LA DEMO --- */
  .grid-demo{display:grid; grid-template-columns: 1fr 1.2fr; gap:2rem; margin-bottom:2.5rem;}
  @media(max-width:900px){ .grid-demo{grid-template-columns:1fr;} }

  .card{background:var(--surface); border:1px solid var(--border-soft); border-radius:var(--radius-lg); padding:1.75rem; box-shadow:0 10px 30px rgba(0,0,0,0.5);}
  .card-h{font-family:'Fraunces',serif; font-size:20px; font-weight:500; margin-bottom:1rem; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border-soft); padding-bottom:0.5rem;}

  /* --- VISTA CLIENTE (PASS) --- */
  .pass{background:#0D1015; border:1px solid var(--border); border-radius:var(--radius-md); overflow:hidden; display:flex; position:relative; transition:background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;}
  .pass.tier-pass-Plata{
    background:linear-gradient(135deg,#0D1015 0%, rgba(199,202,209,0.16) 45%, #0D1015 100%);
    border-color:rgba(199,202,209,0.55);
    box-shadow:0 0 24px rgba(199,202,209,0.08);
  }
  .pass.tier-pass-Oro{
    background:linear-gradient(135deg,#0D1015 0%, rgba(232,200,116,0.22) 45%, #0D1015 100%);
    border-color:rgba(232,200,116,0.6);
    box-shadow:0 0 28px rgba(232,200,116,0.14);
  }
  .pass.tier-pass-Oro::after{
    content:""; position:absolute; inset:0; pointer-events:none;
    background:linear-gradient(115deg, transparent 40%, rgba(255,255,255,0.08) 50%, transparent 60%);
    background-size:250% 250%; animation:shine 6s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce){ .pass.tier-pass-Oro::after{ animation:none; } }
  @keyframes shine{ 0%{background-position:200% 0;} 100%{background-position:-50% 0;} }

  .pass-main{flex:1; padding:1.25rem; position:relative; z-index:1;}
  .pass-stub{width:120px; background:var(--surface-2); display:flex; flex-direction:column; align-items:center; justify-content:center; padding:1rem; border-left:1.5px dashed rgba(242,239,230,0.15); text-align:center; position:relative; z-index:1;}
  .client-name{font-family:'Fraunces',serif; font-size:22px;}
  .tier-badge{font-size:11px; font-weight:600; padding:3px 10px; border-radius:999px; margin-top:4px; display:inline-block;}
  .tier-Bronce{background:rgba(176,141,87,0.2); color:var(--bronze);}
  .tier-Plata{background:rgba(199,202,209,0.2); color:var(--silver);}
  .tier-Oro{background:rgba(232,200,116,0.2); color:var(--oro);}

  .stamp-grid{display:grid; grid-template-columns:repeat(5,1fr); gap:8px; margin:1.25rem 0;}
  .stamp{aspect-ratio:1; border-radius:50%; border:1.5px solid var(--border-soft); display:flex; align-items:center; justify-content:center; font-size:11px; color:var(--text-faint); transition: all 0.3s;}
  .stamp.active{background:radial-gradient(circle at 35% 30%, #3a2f10, #1A1400 72%); border-color:var(--gold); box-shadow:0 0 10px rgba(201,162,39,0.35), inset 0 0 6px rgba(0,0,0,0.5); position:relative;}
  .stamp.active .feather-icon{width:62%; height:62%; background-image:var(--feather-icon); background-size:contain; background-repeat:no-repeat; background-position:center; filter:drop-shadow(0 0 3px rgba(232,200,116,0.5));}
  .reward-banner{background:rgba(232,200,116,0.1); border:1px solid var(--gold); border-radius:var(--radius-md); padding:0.75rem; font-size:12.5px; color:var(--gold-light); margin-top:0.5rem;}

  /* --- BARRA DE NIVELES SEGMENTADA --- */
  .level-track{position:relative; height:6px; background:var(--surface-2); border-radius:999px; margin:14px 4px 22px;}
  .level-fill{position:absolute; top:0; left:0; height:100%; border-radius:999px; background:linear-gradient(90deg, var(--bronze), var(--gold-light)); transition:width 0.5s ease;}
  .level-seg{position:absolute; top:50%; transform:translate(-50%,-50%); width:20px; height:20px; display:flex; align-items:center; justify-content:center; font-size:12px; background:var(--bg); border:1.5px solid var(--border-soft); border-radius:50%;}
  .level-microcopy{font-size:12px; color:var(--gold-light); line-height:1.4; margin-top:-8px; margin-bottom:10px;}

  /* --- TABS ESTILO APP --- */
  .tabs-nav{display:flex; border-top:1px solid var(--border-soft); border-bottom:1px solid var(--border-soft); margin:1.25rem 0 1rem;}
  .tab-btn{flex:1; background:none; border:none; color:var(--text-faint); font-family:inherit; font-size:12px; font-weight:600; padding:10px 4px; cursor:pointer; border-bottom:2px solid transparent; transition:all 0.2s;}
  .tab-btn.active{color:var(--gold-light); border-bottom-color:var(--gold);}
  .tab-btn:hover{color:var(--text);}

  /* --- FEED DE REGALO --- */
  .gift-item{display:flex; align-items:center; gap:10px; padding:10px 0; border-bottom:1px solid var(--border-soft);}
  .gift-item:last-child{border-bottom:none;}
  .gift-emoji{font-size:26px; width:38px; text-align:center;}
  .gift-info{flex:1;}
  .gift-info .m-name{font-size:12.5px; color:var(--text-dim);}
  .gift-info .m-title{font-size:13.5px; font-weight:500; color:var(--text);}
  .gift-price{text-align:right; margin-right:6px;}
  .price-original{font-size:11px; color:var(--text-faint); text-decoration:line-through;}
  .price-final{font-size:14px; font-weight:600; color:var(--gold-light);}
  .btn-mini{background:var(--gold); color:#1A1400; border:none; padding:7px 12px; border-radius:8px; font-size:12px; font-weight:600; cursor:pointer; white-space:nowrap;}
  .btn-mini:hover{background:var(--gold-light);}

  /* --- MIS CUPONES --- */
  .coupon-card{display:flex; justify-content:space-between; align-items:center; background:var(--surface-2); border:1px solid var(--border-soft); border-radius:var(--radius-md); padding:10px 12px; margin-bottom:8px;}
  .coupon-card .code{font-family:'JetBrains Mono',monospace; font-size:15px; color:var(--gold-light); letter-spacing:1px;}
  .coupon-card .meta{font-size:11.5px; color:var(--text-dim);}
  .status-pill{font-size:10.5px; font-weight:700; padding:3px 9px; border-radius:999px; text-transform:uppercase; letter-spacing:0.4px;}
  .status-purchased{background:rgba(95,168,211,0.18); color:#5FA8D3;}
  .status-redeemed{background:rgba(119,178,85,0.18); color:var(--success);}
  .empty-state{font-size:12.5px; color:var(--text-faint); padding:1.5rem 0; text-align:center;}

  /* --- COMPONENTES FORM / TABLAS --- */
  label{display:block; font-size:12px; color:var(--text-dim); margin:10px 0 4px;}
  select, input{width:100%; background:var(--surface-2); border:1px solid var(--border-soft); color:var(--text); padding:10px 12px; border-radius:var(--radius-md); font-family:inherit; outline:none;}
  select:focus, input:focus{border-color:var(--gold);}
  .btn{background:var(--gold); color:#1A1400; border:none; padding:10px 16px; border-radius:var(--radius-md); font-weight:600; cursor:pointer; width:100%; margin-top:10px; transition:all 0.2s;}
  .btn:hover{background:var(--gold-light);}
  .btn-outline{background:transparent; border:1px solid var(--border); color:var(--gold-light); margin-top:8px;}
  .btn-outline:hover{background:rgba(201,162,39,0.05);}
  .btn:disabled{opacity:0.3; cursor:not-allowed;}

  /* --- MODALES --- */
  .modal-overlay{position:fixed; inset:0; background:rgba(5,6,9,0.72); display:none; align-items:center; justify-content:center; z-index:1000; padding:1rem;}
  .modal-overlay.show{display:flex;}
  .modal-box{background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-lg); padding:1.5rem; max-width:380px; width:100%; box-shadow:0 20px 60px rgba(0,0,0,0.6); max-height:90vh; overflow-y:auto;}
  .modal-close{float:right; background:none; border:none; color:var(--text-faint); font-size:18px; cursor:pointer; line-height:1;}
  .modal-title{font-family:'Fraunces',serif; font-size:19px; color:var(--gold-light); margin-bottom:4px;}
  .modal-sub{font-size:12.5px; color:var(--text-dim); margin-bottom:12px;}
  .wa-preview{background:var(--surface-2); border:1px solid var(--border-soft); border-radius:var(--radius-md); padding:10px 12px; font-size:12.5px; color:var(--text); line-height:1.5; margin-top:8px; white-space:pre-wrap;}
  .levelup-box{text-align:center; border-width:1.5px;}
  .levelup-box.lv-Plata{border-color:var(--silver); box-shadow:0 0 30px rgba(199,202,209,0.15);}
  .levelup-box.lv-Oro{border-color:var(--gold); box-shadow:0 0 34px rgba(232,200,116,0.2);}
  .levelup-medal{font-size:44px; margin-bottom:6px;}
  .levelup-perks{text-align:left; font-size:12.5px; color:var(--text-dim); margin:14px 0; padding-left:18px; line-height:1.6;}

  /* --- VALIDADOR DE CUPONES (COMERCIO) --- */
  .coupon-validator{margin-top:1.5rem; border-top:1px dashed var(--border-soft); padding-top:1.1rem;}
  .validator-row{display:flex; gap:8px; align-items:flex-end;}
  .validator-row input{text-transform:uppercase; letter-spacing:2px; font-family:'JetBrains Mono',monospace;}
  .validator-row button{width:auto; white-space:nowrap; margin-top:0;}
  .validate-feedback{margin-top:10px; font-size:12.5px; padding:8px 10px; border-radius:8px; display:none;}
  .validate-feedback.ok{display:block; background:rgba(119,178,85,0.12); color:var(--success); border:1px solid rgba(119,178,85,0.3);}
  .validate-feedback.err{display:block; background:rgba(217,108,95,0.12); color:var(--danger); border:1px solid rgba(217,108,95,0.3);}

  /* --- SIMULADOR DE ESCANEO QR (COMERCIO) --- */
  .qr-steps{list-style:none; padding:0; margin:2px 0 4px; font-size:11.5px; color:var(--text-dim); line-height:1.5;}
  .qr-steps li{padding:2px 0; display:flex; gap:6px;}
  .qr-steps li b{color:var(--gold-light); min-width:14px;}
  .qr-scanner{position:relative; width:150px; height:150px; margin:12px auto 10px; border-radius:14px; background:#05060a; overflow:hidden; display:flex; align-items:center; justify-content:center; border:1px solid var(--border-soft);}
  .qr-scanner.found{border-color:var(--success); box-shadow:0 0 18px rgba(119,178,85,0.25);}
  .qr-scanner .corner{position:absolute; width:22px; height:22px;}
  .qr-scanner .corner.tl{top:8px; left:8px; border-top:3px solid var(--gold); border-left:3px solid var(--gold); border-top-left-radius:6px;}
  .qr-scanner .corner.tr{top:8px; right:8px; border-top:3px solid var(--gold); border-right:3px solid var(--gold); border-top-right-radius:6px;}
  .qr-scanner .corner.bl{bottom:8px; left:8px; border-bottom:3px solid var(--gold); border-left:3px solid var(--gold); border-bottom-left-radius:6px;}
  .qr-scanner .corner.br{bottom:8px; right:8px; border-bottom:3px solid var(--gold); border-right:3px solid var(--gold); border-bottom-right-radius:6px;}
  .scan-line{position:absolute; left:8px; right:8px; height:2px; background:linear-gradient(90deg, transparent, var(--gold-light), transparent); box-shadow:0 0 8px var(--gold-light); animation:scanmove 1.4s ease-in-out infinite;}
  @keyframes scanmove{ 0%{top:10%;} 50%{top:86%;} 100%{top:10%;} }
  @media (prefers-reduced-motion: reduce){ .scan-line{ animation:none; top:50%; } }

  /* --- ARCHITECTURE ARCHIVE (INSPECTOR RELACIONAL) --- */
  .architecture-section{border-top:2px dashed var(--border-soft); padding-top:2rem; margin-top:1rem;}
  .arch-title{font-family:'Fraunces',serif; font-size:22px; color:var(--gold-light); margin-bottom:1rem; display:flex; align-items:center; gap:8px;}
  .tables-container{display:flex; flex-direction:column; gap:1.5rem;}
  .db-table{background:#0D1015; border:1px solid var(--border-soft); border-radius:var(--radius-md); overflow:hidden;}
  .db-table-h{background:var(--surface-2); padding:8px 12px; font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--gold-light); border-bottom:1px solid var(--border-soft); display:flex; justify-content:space-between;}
  .table-wrapper{overflow-x:auto;}
  table{width:100%; border-collapse:collapse; font-size:12.5px; text-align:left;}
  th{padding:8px 12px; background:rgba(242,239,230,0.02); color:var(--text-faint); font-weight:500; text-transform:uppercase; font-size:11px; letter-spacing:0.5px;}
  td{padding:8px 12px; border-top:1px solid var(--border-soft); font-family:'JetBrains Mono',monospace; color:var(--text-dim);}
  td.highlight{color:var(--gold-light); font-weight:600;}
  .pk{color:#D96C5F;} .fk{color:#5FA8D3;}

  .qr-mock{width:70px; height:70px; background:var(--gold-light); padding:4px; border-radius:4px;}
  .qr-mock div{width:100%; height:100%; background:#0D1015; clip-path: polygon(0 0, 40% 0, 40% 40%, 0 40%, 0 0, 60% 60%, 100% 60%, 100% 100%, 60% 100%);}

  .toast{position:fixed; bottom:20px; right:20px; background:var(--gold); color:#1A1400; padding:10px 20px; border-radius:var(--radius-md); font-size:13px; font-weight:600; opacity:0; transition:opacity 0.3s; pointer-events:none; z-index:1200;}
  .toast.show{opacity:1;}
</style>
</head>
<body>

<div class="container">
  <header>
    <h1>Gold Bird — Entorno de Pruebas Core</h1>
    <p>Simulador técnico de niveles, sellos/plumas y Gifting Economy · Inspector de Base de Datos Relacional</p>
  </header>

  <div class="grid-demo">
    <!-- COLUMNA IZQUIERDA: FRONT-END DEL CLIENTE -->
    <div class="card">
      <div class="card-h">📱 Vista App Cliente (PWA)</div>
      <div id="client-view-target"></div>
    </div>

    <!-- COLUMNA DERECHA: PANEL DE CONTROL DEL COMERCIO -->
    <div class="card">
      <div class="card-h">🏪 Panel de Control del Comercio (En Caja)</div>

      <div id="merchant-search-target"></div>

      <div id="merchant-actions-target" style="margin-top:1.5rem;"></div>

      <div class="coupon-validator">
        <label style="margin-top:0;">🎁 Validar Cupón de Regalo / Experiencia</label>
        <div class="validator-row">
          <input type="text" id="coupon-validate-input" placeholder="Ej: 7XQ2K9" maxlength="6">
          <button class="btn" onclick="validateCouponCode()">Validar</button>
        </div>
        <div class="validate-feedback" id="coupon-validate-feedback"></div>
      </div>
    </div>
  </div>

  <!-- SECCIÓN INFERIOR: ARQUITECTURA E INSPECTOR DE BASE DE DATOS -->
  <div class="architecture-section">
    <div class="arch-title">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
      Inspector de Base de Datos Estructural (Looker Studio Ready)
    </div>
    <p style="font-size:13px; color:var(--text-dim); margin-bottom:1.5rem;">Las siguientes tablas representan exactamente el estado relacional en tu base de datos en tiempo real. Modifica el estado arriba para observar cómo fluyen las llaves foráneas y los estados del negocio.</p>

    <div class="tables-container">

      <!-- TABLA USERS -->
      <div class="db-table">
        <div class="db-table-h"><span>📋 Tabla: Users</span><span>Dimension Table</span></div>
        <div class="table-wrapper">
          <table>
            <thead><tr><th><span class="pk">id (PK)</span></th><th>name</th><th>email</th><th>role</th><th>experience_points</th></tr></thead>
            <tbody id="db-users-body"></tbody>
          </table>
        </div>
      </div>

      <!-- TABLA BUSINESSES -->
      <div class="db-table">
        <div class="db-table-h"><span>🏢 Tabla: Businesses</span><span>Configuration Table</span></div>
        <div class="table-wrapper">
          <table>
            <thead><tr><th><span class="pk">id (PK)</span></th><th>name</th><th>puntos_por_sello</th><th>max_sellos_recompensa</th></tr></thead>
            <tbody id="db-businesses-body"></tbody>
          </table>
        </div>
      </div>

      <!-- TABLA LOYALTY CARDS -->
      <div class="db-table">
        <div class="db-table-h"><span>💳 Tabla: LoyaltyCards</span><span>State Table (Fact Summary)</span></div>
        <div class="table-wrapper">
          <table>
            <thead><tr><th><span class="pk">id (PK)</span></th><th><span class="fk">user_id (FK)</span></th><th><span class="fk">business_id (FK)</span></th><th>current_stamps</th><th>total_historical_plumas</th><th>reward_ready</th></tr></thead>
            <tbody id="db-cards-body"></tbody>
          </table>
        </div>
      </div>

      <!-- TABLA GIFTED COUPONS -->
      <div class="db-table">
        <div class="db-table-h"><span>🎁 Tabla: GiftedCoupons</span><span>Fact Table (Gifting Economy)</span></div>
        <div class="table-wrapper">
          <table>
            <thead><tr>
              <th><span class="pk">id (PK)</span></th>
              <th><span class="fk">sender_id (FK)</span></th>
              <th>friend_name</th>
              <th>friend_contact</th>
              <th>merchant_name</th>
              <th>experience_title</th>
              <th>price_paid</th>
              <th>coupon_code</th>
              <th>status</th>
            </tr></thead>
            <tbody id="db-coupons-body"></tbody>
          </table>
        </div>
      </div>

      <!-- TABLA TRANSACTIONS -->
      <div class="db-table">
        <div class="db-table-h"><span>🔥 Tabla: Transactions</span><span>Fact Table (Línea de tiempo para Looker Studio)</span></div>
        <div class="table-wrapper">
          <table>
            <thead><tr><th><span class="pk">id (PK)</span></th><th><span class="fk">card_id (FK)</span></th><th>type</th><th>amount_stamps</th><th>amount_plumas</th><th>fecha_visita</th><th>hora_visita</th></tr></thead>
            <tbody id="db-transactions-body"></tbody>
          </table>
        </div>
      </div>

      <!-- VISTA CALCULADA: CLIENT ACTIVITY (RECURRENCIA Y FIDELIDAD) -->
      <div class="db-table">
        <div class="db-table-h"><span>📊 Vista: ClientActivity</span><span>Vista Calculada (Recurrencia · Fidelidad)</span></div>
        <div class="table-wrapper">
          <table>
            <thead><tr>
              <th><span class="fk">user_id (FK)</span></th>
              <th>cliente</th>
              <th>n° visitas</th>
              <th>primera visita</th>
              <th>última visita</th>
              <th>hora última visita</th>
              <th>recurrencia (días prom.)</th>
              <th>indicador de fidelidad</th>
            </tr></thead>
            <tbody id="db-client-activity-body"></tbody>
          </table>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- MODAL: FORMULARIO DE REGALO (CLICK 2) -->
<div class="modal-overlay" id="gift-form-modal" onclick="if(event.target===this) closeGiftForm()">
  <div class="modal-box" id="gift-form-box"></div>
</div>

<!-- MODAL: RESULTADO DE REGALO / MENSAJE WHATSAPP (POST CLICK 3) -->
<div class="modal-overlay" id="gift-result-modal" onclick="if(event.target===this) closeGiftResult()">
  <div class="modal-box" id="gift-result-box"></div>
</div>

<!-- MODAL: CAMBIO DE NIVEL -->
<div class="modal-overlay" id="levelup-modal" onclick="if(event.target===this) closeLevelUp()">
  <div class="modal-box levelup-box" id="levelup-box"></div>
</div>

<div class="toast" id="toast">Acción ejecutada</div>

<script>
// --- CATÁLOGO DE EXPERIENCIAS AFILIADAS (FEED "REGALAR") ---
const GIFT_CATALOG = [
  { id:"EXP-01", merchant:"Café Central", title:"Vale por 1 Desayuno Completo", price:25, emoji:"☕" },
  { id:"EXP-02", merchant:"Sushi Itto", title:"Vale por 1 Combo para 2 personas", price:60, emoji:"🍣" },
  { id:"EXP-03", merchant:"Spa Urbano", title:"Vale por 1 Masaje Relajante 30 min", price:80, emoji:"💆" },
  { id:"EXP-04", merchant:"Librería Nube", title:"Vale por 1 Libro a elección (hasta S/40)", price:40, emoji:"📚" }
];

// --- MOTOR DE BASE DE DATOS EN MEMORIA ---
const DB = {
  users: [
