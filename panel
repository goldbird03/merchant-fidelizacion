function filterMerchantSearch(query) {
  const select = document.getElementById('merchant-select-client');
  if (!select) return;
  const q = (query || "").trim().toLowerCase();
  const matches = DB.users.filter(u => u.role === 'client')
    .filter(u => !q || u.id.toLowerCase().includes(q) || u.name.toLowerCase().includes(q));

  select.innerHTML = matches.length
    ? matches.map(u => `<option value="${u.id}">${u.name} [ID: ${u.id}]</option>`).join('')
    : `<option disabled selected>Sin coincidencias para "${query}"</option>`;

  if (matches.some(u => u.id === activeClientId)) {
    select.value = activeClientId;
  } else if (matches.length) {
    selectClient(matches[0].id);
  }
}

