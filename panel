        <div class="code">${c.coupon_code}</div>
        <div class="meta">${c.experience_title} · para ${c.friend_name}</div>
      </div>
      <span class="status-pill status-${c.status}">${c.status === 'purchased' ? 'Vigente' : 'Canjeado'}</span>
    </div>
  `).join('');
}

function renderClientComponent() {
  const target = document.getElementById('client-view-target');
  const card = DB.loyaltyCards.find(c => c.user_id === activeClientId);
  const user = DB.users.find(u => u.id === activeClientId);

  if (!card) {
    target.innerHTML = `<p style='color:var(--text-faint)'>Usuario seleccionado no es un rol cliente.</p>`;
    return;
  }

  const tier = getTier(card.total_historical_plumas);

  let tabContent = '';
  if (activeClientTab === 'cards') tabContent = renderTabCards(card);
  else if (activeClientTab === 'gift') tabContent = renderTabGift(tier);
  else tabContent = renderTabCoupons();

  target.innerHTML = `
    <div class="pass tier-pass-${tier}">
      <div class="pass-main">
        <span class="eyebrow" style="font-size:10px; color:var(--text-faint); text-transform:uppercase; letter-spacing:0.5px;">Pase de fidelidad</span>
        <div class="client-name">${user.name}</div>
        <span class="tier-badge tier-${tier}">Rango: ${tier}</span>

        ${renderLevelBlock(card.total_historical_plumas)}
      </div>
      <div class="pass-stub">
        <div class="qr-mock"><div></div></div>
        <div style="font-family:'JetBrains Mono', monospace; font-size:11px; margin-top:8px; color:var(--gold-light);">${card.id}</div>
      </div>
    </div>

    <div class="tabs-nav">
      <button class="tab-btn ${activeClientTab === 'cards' ? 'active' : ''}" onclick="switchClientTab('cards')">🎟️ Mis Tarjetas</button>
      <button class="tab-btn ${activeClientTab === 'gift' ? 'active' : ''}" onclick="switchClientTab('gift')">🎁 Regalar</button>
      <button class="tab-btn ${activeClientTab === 'coupons' ? 'active' : ''}" onclick="switchClientTab('coupons')">💼 Mis Cupones</button>
    </div>
    <div id="tab-content">${tabContent}</div>
  `;
}

function renderMerchantComponent() {
  const target = document.getElementById('merchant-actions-target');
  const card = DB.loyaltyCards.find(c => c.user_id === activeClientId);
  const user = DB.users.find(u => u.id === activeClientId);

  if (!card) {
    target.innerHTML = `<div class="empty-state">Selecciona un cliente válido del lector QR ficticio superior.</div>`;
    return;
  }

  const activity = computeClientActivity(user.id);
  target.innerHTML = `
    <div style="background:var(--surface-2); padding:1rem; border-radius:var(--radius-md); border:1px solid var(--border-soft);">
      <h4 style="font-size:14px; font-weight:600; margin-bottom:4px;">Cliente detectado: ${user.name}</h4>
      <p style="font-size:12px; color:var(--text-dim);">Estado actual de la tarjeta: <b>${card.current_stamps}/10 Sellos</b> | Rango: <b>${getTier(card.total_historical_plumas)}</b></p>
      <p style="font-size:12px; color:var(--text-dim); margin-top:4px;">Última visita: <b style="color:var(--gold-light)">${activity.lastVisit ? formatVisitDate(activity.lastVisit) + ' · ' + activity.lastVisitTime : 'Sin registro'}</b> · Recurrencia: <b>${activity.avgIntervalDays !== null ? 'cada ~' + activity.avgIntervalDays + ' días' : '—'}</b> · Fidelidad: <b>${activity.fidelity}</b></p>

      <button class="btn" onclick="executeAddStamp('${card.id}')" ${card.reward_ready ? 'disabled' : ''}>
        ${card.reward_ready ? 'Ciclo Bloqueado (Falta Canje)' : '⚡ Estampar Tarjeta (+1 Sello / +1 Pluma)'}
      </button>

      <button class="btn btn-outline" onclick="executeRedeemReward('${card.id}')" ${!card.reward_ready ? 'disabled' : ''}>
        🎁 Canjear y Validar Premio (Resetear Ronda)
      </button>
    </div>
  `;
}

function renderInspectorTables() {
  document.getElementById('db-users-body').innerHTML = DB.users.map(u =>
    `<tr><td class="highlight">${u.id}</td><td>${u.name}</td><td>${u.email}</td><td>${u.role}</td><td>${u.experience_points !== undefined ? u.experience_points + ' 🪶' : '—'}</td></tr>`
  ).join('');

  document.getElementById('db-businesses-body').innerHTML = DB.businesses.map(b =>
    `<tr><td class="highlight">${b.id}</td><td>${b.name}</td><td>${b.puntos_por_sello} pluma</td><td>${b.max_sellos_recompensa}</td></tr>`
  ).join('');

  document.getElementById('db-cards-body').innerHTML = DB.loyaltyCards.map(c =>
    `<tr>
      <td class="highlight">${c.id}</td>
      <td>${c.user_id}</td>
      <td>${c.business_id}</td>
      <td style="color:var(--gold-light); font-weight:600;">${c.current_stamps}/10</td>
      <td style="color:#5FA8D3; font-weight:600;">${c.total_historical_plumas} 🪶</td>
      <td style="color:${c.reward_ready ? 'var(--gold)' : 'var(--text-faint)'}">${c.reward_ready ? 'TRUE (Listo)' : 'FALSE'}</td>
     </tr>`
  ).join('');

  document.getElementById('db-coupons-body').innerHTML = DB.giftedCoupons.length === 0
    ? `<tr><td colspan="9" style="color:var(--text-faint); text-align:center; padding:14px;">Sin registros aún — genera un regalo desde la pestaña 🎁 Regalar.</td></tr>`
    : DB.giftedCoupons.map(c => `
      <tr>
        <td class="highlight">${c.id}</td>
        <td>${c.sender_id}</td>
        <td>${c.friend_name}</td>
        <td>${c.friend_contact}</td>
        <td>${c.merchant_name}</td>
        <td>${c.experience_title}</td>
        <td>S/ ${c.price_paid}</td>
        <td style="color:var(--gold-light); font-weight:600;">${c.coupon_code}</td>
        <td style="color:${c.status === 'redeemed' ? 'var(--success)' : '#5FA8D3'}">${c.status}</td>
      </tr>
    `).join('');

  document.getElementById('db-transactions-body').innerHTML = DB.transactions.map(t =>
    `<tr>
      <td class="highlight">${t.id}</td>
      <td>${t.card_id}</td>
      <td style="color:${t.type==='reward_redeem'?'var(--danger)':'#77B255'}">${t.type}</td>
      <td>${t.amount_stamps}</td>
      <td>${t.amount_plumas}</td>
      <td>${t.visit_date ? formatVisitDate(t.visit_date) : '—'}</td>
      <td>${t.created_at}</td>
     </tr>`
  ).join('');

  document.getElementById('db-client-activity-body').innerHTML = DB.users.filter(u => u.role === 'client').map(u => {
    const a = computeClientActivity(u.id);
    const fidelityColor = { alta: 'var(--success)', media: 'var(--gold-light)', baja: 'var(--danger)', nuevo: '#5FA8D3' }[a.fidelityClass] || 'var(--text-faint)';
    return `<tr>
      <td>${u.id}</td>
      <td class="highlight">${u.name}</td>
      <td>${a.totalVisits}</td>
      <td>${a.firstVisit ? formatVisitDate(a.firstVisit) : '—'}</td>
      <td>${a.lastVisit ? formatVisitDate(a.lastVisit) : '—'}</td>
      <td>${a.lastVisitTime || '—'}</td>
      <td>${a.avgIntervalDays !== null ? 'cada ~' + a.avgIntervalDays + ' días' : '—'}</td>
      <td style="color:${fidelityColor}; font-weight:600;">${a.fidelity}</td>
     </tr>`;
  }).join('');
}

function populateSelect() {
  const select = document.getElementById('merchant-select-client');
  if (!select) return;
  select.innerHTML = DB.users
    .filter(u => u.role === 'client')
    .map(u => `<option value="${u.id}">${u.name} [ID: ${u.id}]</option>`).join('');
  select.value = activeClientId;
}

function renderAll() {
  renderClientComponent();
  renderMerchantSearch();
  renderMerchantComponent();
  renderInspectorTables();
}

// Inicialización
document.addEventListener('DOMContentLoaded', () => {
  renderAll();
});
</script>
</body>
</html>
